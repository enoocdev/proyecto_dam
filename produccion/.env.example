# Variables de entorno para el despliegue en produccion
# Copia este archivo como .env y rellena los valores reales
# PostgreSQL
POSTGRES_DB=monitor_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password_segura
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
SECRET_KEY=genera-una-clave-con-python-generar_clave.py
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Django Superusuario
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=cambia_esta_password
DJANGO_SUPERUSER_EMAIL=admin@tu-dominio.com

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Caddy
# Dominio para el certificado TLS automatico de Caddy
# Usa :80 para desarrollo local sin TLS o tu-dominio.com para produccion
DOMAIN=:80
