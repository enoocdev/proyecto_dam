    USERS_USER ||--o{ USERS_USER_GROUPS : belongs_to
    AUTH_GROUP ||--o{ USERS_USER_GROUPS : groups

    USERS_USER ||--o{ USERS_USER_USER_PERMISSIONS : has
    AUTH_PERMISSION ||--o{ USERS_USER_USER_PERMISSIONS : grants

    AUTH_GROUP ||--o{ AUTH_GROUP_PERMISSIONS : has
    AUTH_PERMISSION ||--o{ AUTH_GROUP_PERMISSIONS : grants
